# Copie en .env (gitignoré) pour le dev local : npm run dev
# En prod (Cloudflare Pages) ces variables se mettent dans Settings → Environment variables.

# Clés Clerk — depuis dashboard.clerk.com → API keys
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REMPLACE
CLERK_SECRET_KEY=sk_test_REMPLACE

# Liste d'emails autorisés à accéder au dashboard, séparés par des virgules.
# Toute personne qui se crée un compte Clerk avec un email hors de cette
# liste atterrira sur la page /forbidden au lieu du dashboard.
ALLOWED_EMAILS=ludo@coolbeans.cc,email-de-papa@example.com
