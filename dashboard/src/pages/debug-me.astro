---
import { env } from "cloudflare:workers";
import { createClerkClient } from "@clerk/backend";

const payload: Record<string, unknown> = {};
let httpStatus = 200;

try {
  const client = createClerkClient({
    secretKey: env.CLERK_SECRET_KEY,
    publishableKey: env.PUBLIC_CLERK_PUBLISHABLE_KEY,
  });

  const reqState = await client.authenticateRequest(Astro.request, {
    publishableKey: env.PUBLIC_CLERK_PUBLISHABLE_KEY,
    secretKey: env.CLERK_SECRET_KEY,
  });

  payload.isAuthenticated = reqState.isAuthenticated;
  payload.reason = (reqState as { reason?: string }).reason ?? null;
  payload.status = (reqState as { status?: string }).status ?? null;

  if (reqState.isAuthenticated) {
    const userId = reqState.toAuth()?.userId;
    if (userId) {
      try {
        const user = await client.users.getUser(userId);
        payload.userId = user.id;
        payload.primaryEmailId = user.primaryEmailAddressId;
        payload.allEmails = user.emailAddresses.map((e) => ({
          email: e.emailAddress,
          isPrimary: e.id === user.primaryEmailAddressId,
        }));
        payload.allowedListRaw = env.ALLOWED_EMAILS;
        payload.allowedListParsed = (env.ALLOWED_EMAILS ?? "")
          .split(",")
          .map((s) => s.trim().toLowerCase())
          .filter(Boolean);
      } catch (userErr) {
        payload.getUserError = userErr instanceof Error ? userErr.message : String(userErr);
      }
    } else {
      payload.userIdMissing = true;
    }
  }
} catch (err) {
  httpStatus = 500;
  payload.fatalError = err instanceof Error ? err.message : String(err);
}

return new Response(JSON.stringify(payload, null, 2), {
  status: httpStatus,
  headers: { "content-type": "application/json" },
});
---
