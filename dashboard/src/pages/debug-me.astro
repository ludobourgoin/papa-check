---
import { env } from "cloudflare:workers";

const buildTimePk = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY;

const payload: Record<string, unknown> = {
  envCheck: {
    hasDB: typeof env.DB === "object" && env.DB !== null,
    hasAllowedEmails: typeof env.ALLOWED_EMAILS === "string" && env.ALLOWED_EMAILS.length > 0,
    allowedEmailsLength: env.ALLOWED_EMAILS?.length ?? 0,
    hasSecretKey: typeof env.CLERK_SECRET_KEY === "string" && env.CLERK_SECRET_KEY.length > 0,
    secretKeyPrefix: env.CLERK_SECRET_KEY?.slice(0, 8) ?? null,
    buildTimePkPrefix: buildTimePk ? buildTimePk.slice(0, 10) : null,
    buildTimePkLength: buildTimePk?.length ?? 0,
    bindingsKeys: Object.keys(env as unknown as Record<string, unknown>).sort(),
  },
};

try {
  const { createClerkClient } = await import("@clerk/backend");
  const client = createClerkClient({
    secretKey: env.CLERK_SECRET_KEY,
    publishableKey: buildTimePk,
  });

  const reqState = await client.authenticateRequest(Astro.request, {
    publishableKey: buildTimePk,
    secretKey: env.CLERK_SECRET_KEY,
  });

  payload.auth = {
    isAuthenticated: reqState.isAuthenticated,
    reason: (reqState as { reason?: string }).reason ?? null,
    status: (reqState as { status?: string }).status ?? null,
  };

  if (reqState.isAuthenticated) {
    const userId = reqState.toAuth()?.userId;
    if (userId) {
      const user = await client.users.getUser(userId);
      payload.user = {
        id: user.id,
        primaryEmailId: user.primaryEmailAddressId,
        allEmails: user.emailAddresses.map((e) => ({
          email: e.emailAddress,
          isPrimary: e.id === user.primaryEmailAddressId,
        })),
      };
    }
  }
} catch (err) {
  payload.error = err instanceof Error ? err.message : String(err);
}

return new Response(JSON.stringify(payload, null, 2), {
  headers: { "content-type": "application/json" },
});
---
