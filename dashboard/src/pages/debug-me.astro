---
import { env } from "cloudflare:workers";
import { createClerkClient } from "@clerk/backend";

const client = createClerkClient({
  secretKey: env.CLERK_SECRET_KEY,
  publishableKey: env.PUBLIC_CLERK_PUBLISHABLE_KEY,
});

const reqState = await client.authenticateRequest(Astro.request, {
  publishableKey: env.PUBLIC_CLERK_PUBLISHABLE_KEY,
  secretKey: env.CLERK_SECRET_KEY,
});

if (!reqState.isAuthenticated) {
  return new Response("not authenticated, sign in first", { status: 401 });
}

const userId = reqState.toAuth()?.userId;
const user = userId ? await client.users.getUser(userId) : null;

const seen = {
  userId: user?.id ?? null,
  primaryEmailId: user?.primaryEmailAddressId ?? null,
  allEmails: user?.emailAddresses.map((e) => ({
    id: e.id,
    email: e.emailAddress,
    isPrimary: e.id === user.primaryEmailAddressId,
    verification: e.verification?.status ?? null,
  })),
  primaryEmailLower: user?.emailAddresses
    .find((e) => e.id === user.primaryEmailAddressId)
    ?.emailAddress?.toLowerCase() ?? null,
  allowedListRaw: env.ALLOWED_EMAILS,
  allowedListParsed: (env.ALLOWED_EMAILS ?? "")
    .split(",")
    .map((e) => e.trim().toLowerCase())
    .filter(Boolean),
};

return new Response(JSON.stringify(seen, null, 2), {
  headers: { "content-type": "application/json" },
});
---
