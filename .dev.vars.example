# Copie ce fichier en .dev.vars (gitignoré) et remplis avec tes vrais secrets.
# Utilisé uniquement pour `wrangler dev`.
# En prod, les secrets se configurent via `wrangler secret put NOM`.

TELEGRAM_BOT_TOKEN=123456789:AAEXAMPLE_REMPLACER_PAR_TON_TOKEN
TELEGRAM_FATHER_CHAT_ID=000000000
TELEGRAM_MY_CHAT_ID=000000000
TELEGRAM_WEBHOOK_SECRET=remplace_par_une_chaine_aleatoire_32_chars_minimum
